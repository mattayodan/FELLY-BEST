{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/index.html",
      "destination": "/index.html"
    },
    {
      "source": "/home.html",
      "destination": "/home.html"
    },
    {
      "source": "/shop.html",
      "destination": "/shop.html"
    },
    {
      "source": "/cart.html",
      "destination": "/cart.html"
    },
    {
      "source": "/admin.html",
      "destination": "/admin.html"
    }
  ]
}
